node_modules
.wrangler
dist
.dev.vars
.dev.vars.*
!.dev.vars.example
*.log
packages/harness/src/manifests/bundled.ts
packages/harness/src/skills/bundled.ts

# self-issued JWT signing key (mint-jwt.ts)
