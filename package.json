{
  "name": "felix-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Felix workspace root \u2014 deployable apps in apps/* (api, chat-ui, docs), libraries in packages/* (core harness, commerce, design)",
  "type": "module",
  "scripts": {
    "build:manifests": "pnpm --filter @felix/harness build:manifests",
    "build": "turbo run build",
    "docs:dev": "pnpm --filter @felix/docs dev",
    "docs:build": "pnpm --filter @felix/docs build",
    "docs:deploy": "pnpm --filter @felix/docs run deploy",
    "dev": "pnpm --filter @felix/api dev",
    "dev:remote": "pnpm --filter @felix/api dev:remote",
    "deploy": "pnpm --filter @felix/api run deploy",
    "deploy:staging": "pnpm --filter @felix/api run deploy:staging",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check packages apps",
    "lint:fix": "biome check --write packages apps",
    "format": "biome format --write packages apps",
    "migrate:local": "pnpm --filter @felix/api migrate:local",
    "migrate:staging": "pnpm --filter @felix/api migrate:staging",
    "migrate:production": "pnpm --filter @felix/api migrate:production",
    "db:up": "docker compose up --wait -d db",
    "db:down": "docker compose down",
    "eval": "pnpm --filter @felix/api run eval",
    "chat:dev": "pnpm --filter @felix/chat-ui dev",
    "chat:deploy": "pnpm --filter @felix/chat-ui run deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/vitest-pool-workers": "^0.16.4",
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/node": "^25.7.0",
    "turbo": "^2.5.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2"
}
