{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    "pnpm-workspace.yaml",
    "package.json",
    "biome.json",
    "tsconfig.json"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "src/manifests/bundled.ts",
        "src/skills/bundled.ts"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@felix/api#build": {
      "dependsOn": [
        "^build"
      ],
      "cache": false
    }
  }
}
