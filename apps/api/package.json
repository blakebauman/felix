{
  "name": "@felix/api",
  "version": "0.1.0",
  "private": true,
  "description": "Felix API Worker — the deployable shell: Worker entry, plugin wiring root (installedPlugins), wrangler config, Postgres migrations, and ops scripts. The harness itself is @felix/harness.",
  "type": "module",
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "pnpm --filter @felix/harness build:manifests",
    "dev": "pnpm build && wrangler dev",
    "dev:remote": "pnpm build && wrangler dev --remote",
    "deploy": "pnpm build && wrangler deploy --env production",
    "deploy:staging": "pnpm build && wrangler deploy --env staging",
    "migrate:local": "DATABASE_URL=postgresql://postgres:postgres@localhost:5432/felix node-pg-migrate -m migrations up",
    "migrate:staging": "node-pg-migrate -m migrations up",
    "migrate:production": "node-pg-migrate -m migrations up",
    "eval": "tsx scripts/eval.ts"
  },
  "dependencies": {
    "@felix/commerce": "workspace:*",
    "@felix/harness": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/pg": "^8.20.0",
    "jose": "^6.2.3",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0",
    "tsx": "^4.21.0",
    "wrangler": "^4.90.1"
  },
  "engines": {
    "node": ">=20"
  }
}
